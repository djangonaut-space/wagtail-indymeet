# Production environment variables for djangonaut.space
# Copy this file, fill in the values, and deploy via your platform's environment config.
# Do NOT commit the filled-in version to source control.

DEBUG=False
# Labels emails sent in non-production environments. Must be "production" here.
ENVIRONMENT=production
# SSL is enabled by default when DEBUG=False. Set to "false" only for local
# testing against a non-SSL database.
DATABASE_SSL=true
STATICFILES_BACKEND=django.contrib.staticfiles.storage.ManifestStaticFilesStorage
# DatabaseBackend is the default when DEBUG=False. Override only if switching backends.
TASK_BACKEND=django_tasks_db.DatabaseBackend
EMAIL_BACKEND=anymail.backends.mailjet.EmailBackend
# Absolute base URL used when constructing links in emails.
BASE_URL=https://djangonaut.space

SECRET_KEY=
DATABASE_URL=
MAILJET_API_KEY=
MAILJET_SECRET_KEY=
RECAPTCHA_PUBLIC_KEY=
RECAPTCHA_PRIVATE_KEY=
SENTRY_DNS=
# Semicolon-separated list of emails that can receive transactional email
# in non-production environments. Leave empty in production.
ALLOWED_EMAILS_FOR_TESTING=
# Set to any non-empty value to suppress confirmation emails during load tests.
LOAD_TESTING=
